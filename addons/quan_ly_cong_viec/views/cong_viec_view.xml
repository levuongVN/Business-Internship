<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_cong_viec_form" model="ir.ui.view">
        <field name="name">cong.viec.form</field>
        <field name="model">cong_viec</field>
        <field name="arch" type="xml">
            <form string="Công việc">
                <header>
                    <field name="trang_thai" widget="statusbar" options="{'clickable': '1'}"/>
                    <button name="ai_predict_priority" type="object" string="AI gợi ý ưu tiên" class="btn-primary" icon="fa-magic"/>
                    <button name="action_open_quick_summary" type="object" string="Tóm tắt nhanh" class="btn-secondary" icon="fa-bolt"/>
                    <button name="action_open_chatbot" type="object" string="Chat bot công việc" class="btn-secondary" icon="fa-comments-o"/>
                    <button name="action_create_hop_dong" type="object" string="Tạo hợp đồng" class="oe_highlight" attrs="{'invisible': [('trang_thai', '!=', 'hoan_thanh')]}"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_hop_dong" type="object" class="oe_stat_button" icon="fa-file-text-o" attrs="{'invisible': [('hop_dong_count', '=', 0)]}">
                            <field name="hop_dong_count" string="Hợp đồng" widget="statinfo"/>
                        </button>
                        <button name="action_open_chatbot" type="object" class="oe_stat_button" icon="fa-comments-o">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Chat bot</span>
                            </div>
                        </button>
                        <button name="action_open_quick_summary" type="object" class="oe_stat_button" icon="fa-bolt">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Tóm tắt nhanh</span>
                            </div>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="ten_cong_viec" placeholder="Tên công việc..."/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="nhan_vien_thuc_hien_id"/>
                            <field name="khach_hang_id"/>
                            <field name="tuong_tac_id" options="{'no_create': True}"/>
                            <field name="loai_cong_viec_id"/>
                        </group>
                        <group>
                            <field name="nguon_tao"/>
                            <field name="ngay_bat_dau"/>
                            <field name="han_chot"/>
                            <field name="ngay_hoan_thanh" readonly="1"/>
                            <field name="muc_do_uu_tien" widget="priority"/>
                            <field name="is_qua_han" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Mô tả">
                            <field name="mo_ta"/>
                        </page>
                        <page string="Kết quả xử lý">
                            <field name="ket_qua_xu_ly"/>
                        </page>
                        <page string="Lý do hủy" attrs="{'invisible': [('trang_thai', '!=', 'huy')]}">
                            <field name="ly_do_huy" placeholder="Ghi rõ lý do công việc bị hủy..."/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_cong_viec_tree" model="ir.ui.view">
        <field name="name">cong.viec.tree</field>
        <field name="model">cong_viec</field>
        <field name="arch" type="xml">
            <tree string="Công việc" decoration-danger="is_qua_han or trang_thai == 'huy'" decoration-success="trang_thai == 'hoan_thanh'" decoration-info="trang_thai == 'moi'" decoration-warning="trang_thai == 'dang_lam'">
                <field name="ten_cong_viec"/>
                <field name="khach_hang_id"/>
                <field name="tuong_tac_id"/>
                <field name="nhan_vien_thuc_hien_id"/>
                <field name="nguon_tao"/>
                <field name="han_chot"/>
                <field name="muc_do_uu_tien" widget="priority"/>
                <field name="trang_thai" widget="badge"/>
                <field name="is_qua_han" optional="hide"/>
                <field name="ly_do_huy" optional="hide"/>
            </tree>
        </field>
    </record>

    <record id="view_cong_viec_kanban" model="ir.ui.view">
        <field name="name">cong.viec.kanban</field>
        <field name="model">cong_viec</field>
        <field name="arch" type="xml">
            <kanban default_group_by="trang_thai" class="o_kanban_small_column">
                <field name="ten_cong_viec"/>
                <field name="khach_hang_id"/>
                <field name="nhan_vien_thuc_hien_id"/>
                <field name="muc_do_uu_tien"/>
                <field name="han_chot"/>
                <field name="is_qua_han"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="oe_kanban_content">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="ten_cong_viec"/>
                                    </strong>
                                </div>
                                <div class="mt8">
                                    <div><field name="khach_hang_id"/></div>
                                    <div><field name="nhan_vien_thuc_hien_id"/></div>
                                    <div><field name="han_chot"/></div>
                                </div>
                                <div class="mt8 d-flex justify-content-between align-items-center">
                                    <field name="muc_do_uu_tien" widget="priority"/>
                                    <span t-if="record.is_qua_han.raw_value" class="badge badge-danger">Quá hạn</span>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_cong_viec_search" model="ir.ui.view">
        <field name="name">cong.viec.search</field>
        <field name="model">cong_viec</field>
        <field name="arch" type="xml">
            <search string="Tìm kiếm công việc">
                <field name="ten_cong_viec"/>
                <field name="nhan_vien_thuc_hien_id"/>
                <field name="khach_hang_id"/>
                <field name="tuong_tac_id"/>
                <field name="nguon_tao"/>
                <filter string="Việc của tôi" name="my_tasks" domain="[('nhan_vien_thuc_hien_id.user_id', '=', uid)]"/>
                <filter string="Quá hạn" name="overdue" domain="[('is_qua_han', '=', True)]"/>
                <filter string="Hôm nay" name="today" domain="[('han_chot', '=', context_today().strftime('%Y-%m-%d'))]"/>
                <filter string="Tuần này" name="this_week" domain="[('han_chot', '&gt;=', context_today().strftime('%Y-%m-%d')), ('han_chot', '&lt;=', (context_today() + relativedelta(days=6)).strftime('%Y-%m-%d'))]"/>
                <group expand="0" string="Group By">
                    <filter string="Khách hàng" name="group_by_khach_hang" context="{'group_by': 'khach_hang_id'}"/>
                    <filter string="Nhân viên" name="group_by_nhan_vien" context="{'group_by': 'nhan_vien_thuc_hien_id'}"/>
                    <filter string="Tương tác" name="group_by_tuong_tac" context="{'group_by': 'tuong_tac_id'}"/>
                    <filter string="Trạng thái" name="group_by_trang_thai" context="{'group_by': 'trang_thai'}"/>
                    <filter string="Nguồn tạo" name="group_by_nguon_tao" context="{'group_by': 'nguon_tao'}"/>
                    <filter string="Ưu tiên" name="group_by_uu_tien" context="{'group_by': 'muc_do_uu_tien'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_cong_viec_pivot" model="ir.ui.view">
        <field name="name">cong.viec.pivot</field>
        <field name="model">cong_viec</field>
        <field name="arch" type="xml">
            <pivot string="Báo cáo công việc">
                <field name="nhan_vien_thuc_hien_id" type="row"/>
                <field name="trang_thai" type="col"/>
            </pivot>
        </field>
    </record>

    <record id="view_cong_viec_graph" model="ir.ui.view">
        <field name="name">cong.viec.graph</field>
        <field name="model">cong_viec</field>
        <field name="arch" type="xml">
            <graph string="Biểu đồ công việc" type="bar">
                <field name="nhan_vien_thuc_hien_id"/>
                <field name="trang_thai" type="col"/>
            </graph>
        </field>
    </record>

    <record id="action_cong_viec" model="ir.actions.act_window">
        <field name="name">Công việc</field>
        <field name="res_model">cong_viec</field>
        <field name="view_mode">kanban,tree,form,pivot,graph</field>
        <field name="search_view_id" ref="view_cong_viec_search"/>
        <field name="context">{}</field>
    </record>

    <record id="action_bao_cao_cong_viec" model="ir.actions.act_window">
        <field name="name">Báo cáo công việc</field>
        <field name="res_model">cong_viec</field>
        <field name="view_mode">graph,pivot,tree</field>
        <field name="search_view_id" ref="view_cong_viec_search"/>
        <field name="context">{'search_default_group_by_nhan_vien': 1}</field>
    </record>
</odoo>
