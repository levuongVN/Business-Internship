<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_nhan_vien_form_inherit" model="ir.ui.view">
        <field name="name">nhan.vien.form.inherit</field>
        <field name="model">nhan_vien</field>
        <field name="inherit_id" ref="nhan_su.view_nhan_vien_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('oe_read_only')]" position="before">
                <div class="oe_button_box" name="button_box">
                    <button name="action_view_cong_viec" type="object" class="oe_stat_button" icon="fa-tasks">
                        <field name="cong_viec_ids" widget="statinfo" string="Công việc"/>
                    </button>
                </div>
            </xpath>
            <xpath expr="//field[@name='email']" position="after">
                <field name="user_id"/>
            </xpath>
        </field>
    </record>
</odoo>
